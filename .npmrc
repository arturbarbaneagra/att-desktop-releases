# CI build config (GitHub Windows runner).
# ignore-scripts: skip package lifecycle scripts during `npm ci`. Electron's
# postinstall downloads a ~100 MB platform binary that intermittently crashed
# npm ("Exit handler never called!") and left node_modules empty. This app has
# no native modules that need build scripts, and electron-builder downloads its
# own Electron dist at build time, so skipping install scripts is safe and makes
# the install fast and reliable.
ignore-scripts=true
audit=false
fund=false
